{
    "name": "ai-farmer-advisory-unified",
    "version": "1.0.0",
    "scripts": {
        "start": "node server/index.js",
        "server": "node --watch server/index.js",
        "client": "npm run dev --prefix client -- --clearScreen false",
        "ml": "cd ml && python app.py",
        "dev": "concurrently -n \"SERVER,CLIENT,ML\" -c \"yellow,blue,green\" \"npm run server\" \"npm run client\" \"npm run ml\"",
        "build": "npm install --prefix client && npm run build --prefix client && rm -rf dist && mv client/dist dist"
    },
    "dependencies": {
        "axios": "^1.13.5",
        "bcryptjs": "^3.0.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.1",
        "jsonwebtoken": "^9.0.3",
        "lru-cache": "^11.2.7",
        "mongoose": "^9.2.3"
    },
    "devDependencies": {
        "concurrently": "^9.2.1"
    }
}
