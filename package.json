{
  "name": "ai-farmer-advisory",
  "version": "1.0.0",
  "description": "AI-Powered Farmer Advisory Platform",
  "main": "backend/src/server.js",
  "scripts": {
    "install-all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "full-stack": "concurrently \"npm run backend\" \"npm run frontend\" \"npm run ml\"",
    "backend": "cd backend && npm run dev",
    "frontend": "cd frontend && npm run dev",
    "ml": "cd ml && python ml_api.py",
    "start": "cd backend && npm start"
  },
  "keywords": [
    "agriculture",
    "ai",
    "farmer",
    "crop-recommendation",
    "mandi-prices",
    "satellite-ndvi"
  ],
  "author": "Sakalesha",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
